{
  "manifest_version": 3,
  "name": "JPDB Immersion Kit Examples",
  "version": "1.25.0",
  "description": "Embeds Immersion Kit examples into jpdb.io review, vocabulary, kanji, and search pages.",
  "icons": {
    "16": "icons/icon-16.png",
    "32": "icons/icon-32.png",
    "48": "icons/icon-48.png",
    "96": "icons/icon-96.png",
    "128": "icons/icon-128.png",
    "384": "icons/icon-384.png"
  },
  "permissions": [
    "storage"
  ],
  "host_permissions": [
    "https://jpdb.io/*",
    "https://apiv2.immersionkit.com/*",
    "https://us-southeast-1.linodeobjects.com/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "options_ui": {
    "page": "options.html"
  },
  "action": {
    "default_title": "JPDB Immersion Kit Examples",
    "default_icon": {
      "16": "icons/icon-16.png",
      "32": "icons/icon-32.png",
      "48": "icons/icon-48.png",
      "96": "icons/icon-96.png",
      "128": "icons/icon-128.png"
    }
  },
  "content_scripts": [
    {
      "matches": [
        "https://jpdb.io/review*",
        "https://jpdb.io/vocabulary/*",
        "https://jpdb.io/kanji/*",
        "https://jpdb.io/search*"
      ],
      "css": [
        "dictation-prehide.css"
      ],
      "js": [
        "settings.js",
        "dictation-bootstrap.js"
      ],
      "run_at": "document_start"
    },
    {
      "matches": [
        "https://jpdb.io/review*",
        "https://jpdb.io/vocabulary/*",
        "https://jpdb.io/kanji/*",
        "https://jpdb.io/search*"
      ],
      "js": [
        "settings.js",
        "content.js"
      ],
      "run_at": "document_idle"
    }
  ]
}
